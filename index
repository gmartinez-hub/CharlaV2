<script>
const slides = Array.from(document.querySelectorAll('.slide'));
const total = slides.length;
let cur = 0;

function ui() {
  document.getElementById('prog').style.width = (cur / (total - 1) * 100) + '%';
  document.getElementById('ct').textContent =
    String(cur + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');
}

function goTo(idx) {
  if (idx < 0 || idx >= total) return;
  slides[cur].classList.remove('active');
  slides[cur].classList.add('out');
  setTimeout(() => slides[cur].classList.remove('out'), 400);
  cur = idx;
  slides[cur].classList.add('active');
  ui();
}

function next() { goTo(cur + 1); }
function prev() { goTo(cur - 1); }

document.addEventListener('keydown', e => {
  if (['ArrowRight', 'ArrowDown', ' '].includes(e.key)) { e.preventDefault(); next(); }
  if (['ArrowLeft', 'ArrowUp'].includes(e.key)) { e.preventDefault(); prev(); }
  if (e.key === 'Escape') goTo(0);
});

let tx = 0;
document.addEventListener('touchstart', e => tx = e.touches[0].clientX, { passive: true });
document.addEventListener('touchend', e => {
  const dx = e.changedTouches[0].clientX - tx;
  if (Math.abs(dx) > 60) dx < 0 ? next() : prev();
}, { passive: true });

ui();
</script>
